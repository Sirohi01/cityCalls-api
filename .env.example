NODE_ENV=development
PORT=4000

MONGODB_URI=mongodb://localhost:27017/citycalls
REDIS_URL=redis://localhost:6379

JWT_ACCESS_SECRET=change-me-in-every-environment
JWT_REFRESH_SECRET=change-me-in-every-environment
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

CORS_ALLOWED_ORIGINS=http://localhost:3000

# Seed script (scripts/seed.ts) — required to create the first Super Admin user.
SEED_SUPER_ADMIN_EMAIL=superadmin@citycalls.local
SEED_SUPER_ADMIN_MOBILE=9999999999
SEED_SUPER_ADMIN_PASSWORD=12345678

# Cloudinary — optional integration, docs/14-integration-architecture.md §2
CLOUDINARY_ENABLED=false
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# SMTP — optional integration, docs/14-integration-architecture.md §3
SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# AiSensy WhatsApp — optional integration, docs/14-integration-architecture.md §4
AISENSY_ENABLED=false
AISENSY_API_KEY=

# AI (Gemini/OpenAI) — optional integration, docs/14-integration-architecture.md §5
AI_ENABLED=false
AI_PROVIDER=
GEMINI_API_KEY=
OPENAI_API_KEY=

# Firebase Admin SDK — push notifications (PUSH channel). Distinct from the
# mobile app's google-services.json (client SDK config). Download a service
# account key from Firebase Console > Project Settings > Service Accounts >
# Generate New Private Key. Either point to the downloaded file, or paste its
# full JSON contents into FIREBASE_SERVICE_ACCOUNT_JSON (wins if both set).
FIREBASE_ENABLED=false
FIREBASE_SERVICE_ACCOUNT_PATH=
FIREBASE_SERVICE_ACCOUNT_JSON=
